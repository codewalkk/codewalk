# ── Rust / Cargo ─────────────────────────────────────────────────────────────
# Build artifacts. The workspace builds binaries (`codegraph`, `codewalk`), so
# Cargo.lock IS committed (do not ignore it) — only the build output is ignored.
/target/
**/*.rs.bk
*.pdb

# ── codegraph / codewalk generated data ──────────────────────────────────────
# Per-repo index + KB databases (rusqlite + WAL/SHM sidecars). These are
# generated by `codegraph index` / `codewalk` and must never be committed —
# re-indexing recreates the structural store; the KB is machine-local.
.codegraph/
.codewalk/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Embedding model cache (fastembed MiniLM weights), if ever cached in-tree.
/models/
*.onnx

# ── Editor / OS ──────────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
docs/vibe_summaries.md
